# Copy this file to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars to version control

aws_region     = "us-east-1"
project        = "energygrid"
environment    = "prod"
aws_account_id = "123456789012"      # Your 12-digit AWS account ID
key_name       = "energygrid-key"    # Name of your EC2 key pair (without .pem)

# Security: use strong passwords
db_password = "ChangeMe_S3cur3Pass!"
jwt_secret  = "change-this-to-a-long-random-secret-string-64chars"

# Pingdom (optional — leave empty strings if not using)
pingdom_api_token = ""
pingdom_email     = ""

# Restrict SSH access to your IP for security (recommended)
# Get your IP: curl ifconfig.me
allowed_ssh_cidr = "0.0.0.0/0"
